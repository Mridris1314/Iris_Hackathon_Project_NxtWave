# Get a free Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
# Any long random string — it signs login tokens.
JWT_SECRET=change-this-to-a-long-random-string
# SQLite for local dev; set to your PostgreSQL URL on Render/Railway
DATABASE_URL=sqlite:///./iris.db
# Comma-separated production frontend URLs (added to CORS allowlist automatically)
# Example: https://iris.vercel.app,https://iris.netlify.app
ALLOWED_ORIGINS=
# Max /describe calls per user per minute (default: 15)
DESCRIBE_RATE_LIMIT=15
